{
  "name": "eslint-config",
  "private": true,
  "scripts": {
    "change": "rush change",
    "publish": "rush publish -a -p --set-access-level=public --registry=https://registry.npmjs.org/",
    "test": "rush test",
    "update-snap": "rush update-snap"
  },
  "homepage": "https://github.com/lemonbot-fun/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lemonbot-fun/eslint-config.git"
  },
  "commitlint": {
    "extends": [
      "gitmoji"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^16.2.3",
    "@lemonbot.fun/eslint-config-base": "^1.3.0",
    "@typescript-eslint/parser": "^5.17.0",
    "@typescript-eslint/eslint-plugin": "^5.17.0",
    "commitlint-config-gitmoji": "^2.2.5",
    "eslint": "^8.12.0",
    "eslint-plugin-compat": "^4.0.2",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-unused-imports": "^2.0.0",
    "husky": "^7.0.4"
  },
  "version": "0.1.0",
  "packageManager": "pnpm"
}
